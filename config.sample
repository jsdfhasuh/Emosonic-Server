[base]
; A database URI. See the 'schema' folder for schema creation scripts. Note that
; you don't have to run these scripts yourself.
; Default: sqlite:////tmp/supysonic/supysonic.db
;database_uri = sqlite:////var/supysonic/supysonic.db
;database_uri = mysql://supysonic:supysonic@localhost/supysonic
;database_uri = postgres://supysonic:supysonic@localhost/supysonic

; Optional, restrict scanner to these extensions. Default: none
;scanner_extensions = mp3 ogg

; Should the scanner follow symbolic links? Default: no
follow_symlinks = no

[webapp]
; Optional cache directory. Default: /tmp/supysonic
cache_dir = /var/supysonic/cache

; Main cache max size in MB. Default: 512
cache_size = 512

; Transcode cache max size in MB. Default: 1024 (1GB)
transcode_cache_size = 1024

; Optional log directory for structured web logs. When set, Supysonic writes
; supysonic.log, access.log, task.log, emo.log, scanner.log, api.log and
; metadata.log here. At DEBUG level it also writes web.debug.log.
; Default: none
log_dir = /log/web

; Number of rotated log files to keep. Default: 7
log_backup_count = 7

; Log level. Possible values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
; Default: WARNING
log_level = WARNING

; Enable log rotation. Default: yes
log_rotate = yes

; Enable the Subsonic REST API. You'll most likely want to keep this on, here
; for testing purposes. Default: on
;mount_api = on

; Enable the administrative web interface. Default: on
;mount_webui = on

; Enable the emosonic extension endpoints. Default: off
;mount_emosonic = on

; Enable the emosonic websocket endpoint at /emo/ws. Default: on
;emo_ws_enabled = on

; Exact comma-separated origins allowed to open the Emo Socket.IO endpoint.
; Empty means same-origin only. A wildcard is rejected outside explicit
; development mode. Default: empty
;emo_allowed_origins = https://music.example
;emo_development_mode = off

; Socket.IO heartbeat and per-connection pending emit limits.
; Defaults: ping interval 25s, ping timeout 20s, 100 pending emits.
;emo_socketio_ping_interval = 25
;emo_socketio_ping_timeout = 20
;emo_socketio_max_pending_emits_per_connection = 100

; Emo connection limits. Defaults: 10 unauthenticated connections per IP and
; 20 authenticated connections per user.
;emo_unauthenticated_connections_per_ip = 10
;emo_authenticated_connections_per_user = 20

; Strict-v2 action limits. Higher values are ignored unless the load-test
; evidence setting names reviewed evidence. Lower positive values are allowed.
;emo_strict_requests_per_connection_per_minute = 120
;emo_strict_controls_per_connection_per_second = 20
;emo_strict_creates_per_connection_per_minute = 10
;emo_strict_handoff_starts_per_connection_per_minute = 10
;emo_strict_broadcast_starts_per_connection_per_minute = 10
;emo_strict_rate_limit_load_test_evidence =

; Seconds allowed for in-flight strict-v2 requests to settle during graceful
; shutdown before remaining Socket.IO connections are closed. Default: 5
;emo_strict_shutdown_grace_seconds = 5

; Seconds before a registered Emo Socket.IO client is considered offline if it
; sends no business message or system.ping. Set to 0 to disable stale cleanup.
; Default: 90
;emo_client_timeout = 90

; Strict-v2 profiles require both packaged conformance readiness and an explicit
; deployment switch. Keep these disabled until the matching freeze evidence exists.
;emo_strict_v2_core_enabled = off
;emo_strict_v2_follow_enabled = off
;emo_strict_v2_handoff_enabled = off
;emo_strict_v2_broadcast_enabled = off

; Development/test deployments may explicitly accept packaged
; local-test-only conformance evidence for external client integration.
; This switch is ignored unless emo_development_mode is also on. Never enable
; either setting in production. Default: off
;emo_strict_v2_allow_local_test_evidence = off

; Select the browser implementation rendered by both /player and /control.
; Allowed values: legacy, strict_v2. There is no automatic fallback.
; Default: legacy
;emo_web_realtime_protocol = legacy

; Lifetime of the same-origin, session-bound browser Socket.IO password.
; The credential is one-time use and is never written to browser storage.
; Default: 60 seconds
;emo_browser_otp_ttl_seconds = 60

; Browser password issuance limits. A session may hold a small number of
; outstanding one-time passwords so player and control tabs can bootstrap
; concurrently. Defaults: 12 issues/minute/session, 4 outstanding/session,
; and 10000 outstanding credentials globally.
; The global capacity also bounds active per-session rate-limit windows.
;emo_browser_otp_issues_per_session_per_minute = 12
;emo_browser_otp_outstanding_per_session = 4
;emo_browser_otp_global_capacity = 10000

; Optional strict-v2 browser profiles remain disabled until their browser
; acceptance evidence has been reviewed. These gates do not override the
; corresponding server readiness settings.
;emo_web_strict_v2_follow_enabled = off
;emo_web_strict_v2_handoff_enabled = off
;emo_web_strict_v2_broadcast_enabled = off

; Directory used by /emo/upload_log and /emo/logs for uploaded diagnostic files.
; Default: ./logs
emo_log_upload_dir = /var/supysonic/emo-logs

; Enable public client release endpoints at /client-releases. Default: on
mount_client_releases = on

; Directory used to store uploaded APK and Windows client installers.
; Default: /tmp/supysonic/client-releases
release_upload_dir = /var/supysonic/client-releases

; Token required for POST /client-releases/publish. Leave empty to disable publishing.
; Generate one with: openssl rand -hex 32
release_api_token =

; Maximum client installer upload size in bytes. Default: 536870912 (512MB)
release_max_upload_size = 536870912

; Space separated list of prefixes that should be ignored on index endpoints
; Default: El La Le Las Les Los The
index_ignored_prefixes = El La Le Las Les Los The

; Enable the ChartLyrics API. Default: off
online_lyrics = off

[daemon]
; Socket file the daemon will listen on for incoming management commands
; Default: /tmp/supysonic/supysonic.sock
socket = /var/run/supysonic.sock

; Defines if the file watcher should be started. Default: yes
run_watcher = yes

; Delay in seconds before triggering scanning operation after a change have been
; detected.
; This prevents running too many scans when multiple changes are detected for a
; single file over a short time span. Default: 5
wait_delay = 5

; Command used by the jukebox
jukebox_command = mplayer -ss %offset %path

; Optional log directory for daemon logs. When set, Supysonic writes
; supysonic.log, daemon.log, watcher.log, scanner.log and, at DEBUG level,
; daemon.debug.log here. Default: none
log_dir = /log/daemon

; Number of rotated log files to keep. Default: 7
log_backup_count = 7

log_level = INFO
log_rotate = yes

; Enable daemon-driven daily mood/scene playlist refresh. Default: on.
; This does not call an LLM; it uses existing high-quality semantic metadata.
mood_scene_playlists_daily_refresh = on

; Poll interval in seconds for the mood/scene playlist scheduler. The scheduler
; still refreshes at most once per natural day. Default: 300
mood_scene_playlists_refresh_interval = 300

; Maximum tracks per generated mood/scene playlist. Default: 30
mood_scene_playlist_size = 30

; Number of days of system mood/scene playlists to keep. Default: 1
mood_scene_playlist_retention_days = 1

; Only auto-generate for users with play activity or a last-play track. Default: on
mood_scene_playlists_active_users_only = on

; Enable daemon-driven track recommendation metadata enrichment. Default: off.
; Keep this disabled unless you explicitly want the daemon to enrich tracks
; on a timer.
track_metadata_enrichment = off

; Provider for daemon-driven track metadata enrichment. "local" does not call
; external services. "llm" uses [recommendation_agent] api_base_url, api_key,
; model, timeout_seconds, max_output_tokens and temperature. Default: local
track_metadata_enrichment_provider = local

; Poll interval in seconds for track metadata enrichment. Default: 300
track_metadata_enrichment_interval = 300

; Maximum tracks enriched per daemon pass. Default: 10
track_metadata_enrichment_batch_size = 10

; Seconds before a running enrichment task is considered stale. Default: 900
track_metadata_enrichment_stale_lock_seconds = 900

; Allow full path hints to be sent to an enrichment provider. Default: off
track_metadata_enrichment_send_path_hints = off

; Log generated mood/scene/tag/summary fields for each enriched track.
; This can be noisy and may expose semantic summaries in logs. Default: off
track_metadata_enrichment_log_payload = off

; Example for scheduled LLM enrichment:
;   track_metadata_enrichment = yes
;   track_metadata_enrichment_provider = llm
;   track_metadata_enrichment_interval = 300
;   track_metadata_enrichment_batch_size = 10
; The interval is 5 minutes in this example. Increase batch size cautiously to
; avoid provider rate limits and quota usage.

[musicbrainz]
; MusicBrainz is the default structured album enrichment source.
; Enrichment only fills empty album/track metadata and may create an
; external_enrichment review task after automatic writes.
; Defaults: https://musicbrainz.org/ws/2
;api_url = https://musicbrainz.org/ws/2

; Cover Art Archive root URL used by MusicBrainz cover lookups.
; Defaults: https://coverartarchive.org
;cover_art_api_url = https://coverartarchive.org

; User-Agent sent to MusicBrainz. Set a contact-aware value for production.
; Defaults: Supysonic/1.0
;user_agent = Supysonic/1.0

; Delay between MusicBrainz enrichment requests, in seconds. Default: 1.0
;request_delay_seconds = 1.0

[discogs]
; Optional Discogs album enrichment. Disabled unless enabled and token is set.
; Rate limits, HTTP errors and network failures are logged and skipped without
; blocking MusicBrainz enrichment or scans.
;enabled = off

; Defaults: https://api.discogs.com
;api_url = https://api.discogs.com

; Discogs personal access token. Do not commit real tokens.
;token =

; User-Agent sent to Discogs. Set a contact-aware value for production.
; Defaults: Supysonic/1.0
;user_agent = Supysonic/1.0

; Delay between Discogs enrichment requests, in seconds. Default: 1.0
;request_delay_seconds = 1.0

[lastfm]
; API and secret key to enable scrobbling. http://www.last.fm/api/accounts
; Defaults: none
;api_key =
;secret =

[listenbrainz]
; root URL of the ListenBrainz API.
; Defaults: https://api.listenbrainz.org/
;api_url =

[recommendation_agent]
; OpenAI-compatible model endpoint for the recommendation page Agent.
; Disabled unless enabled, api_key, and model are set.
; Track metadata LLM enrichment reuses this endpoint/key/model when explicitly
; selected, but does not require recommendation_agent.enabled.
enabled = off

; Defaults: https://api.openai.com/v1
api_base_url = https://api.openai.com/v1

; API key for the OpenAI-compatible provider. Do not commit real keys.
api_key =

; Model name sent to /chat/completions.
model =

; Request timeout in seconds. Default: 20
timeout_seconds = 20

; Recent user play records sent to the model. Default: 200
history_limit = 200

; Maximum model output tokens. Set to 0 to omit max_tokens and let the
; provider use its model limit. Default: 900
max_output_tokens = 900

; Model temperature. Default: 0.7
temperature = 0.7

; Seconds to reuse identical Agent results for the same user/context.
; Set to 0 to disable Agent result caching. Default: 900
cache_ttl_seconds = 900

[transcoding]
; Programs used to convert from one format/bitrate to another. Defaults: none
transcoder_mp3_mp3 = lame --quiet --mp3input -b %outrate %srcpath -
transcoder = ffmpeg -i %srcpath -ab %outratek -v 0 -f %outfmt -
decoder_mp3 = mpg123 --quiet -w - %srcpath
decoder_ogg = oggdec -Q -o - %srcpath
decoder_flac = flac -d -c -s %srcpath
encoder_mp3 = lame --quiet -b %outrate - -
encoder_ogg = oggenc2 -Q -M %outrate -

; Default format, used when a client requests a bitrate lower than the original
; file and no specific format
default_transcode_target = mp3

[mimetypes]
; Extension to mimetype mappings in case your system has some trouble guessing
; Default: none
;mp3 = audio/mpeg
;ogg = audio/vorbis
