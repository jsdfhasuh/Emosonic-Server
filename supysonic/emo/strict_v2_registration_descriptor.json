{
  "protocolName": "emosonic-playback-context-v2-registration",
  "protocolVersion": "2.2.0",
  "coveredActions": {
    "clientToServer": [
      "device.register"
    ],
    "serverToClient": [
      "system.ack(device.register)",
      "system.error(device.register)"
    ]
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "EmoSonic strict-v2 registration handshake",
    "description": "The strict-v2 device registration request and its responses.",
    "oneOf": [
      {
        "$ref": "#/$defs/strictRegisterRequest"
      },
      {
        "$ref": "#/$defs/strictRegisterAck"
      },
      {
        "$ref": "#/$defs/registerError"
      }
    ],
    "$defs": {
      "nonEmptyString": {
        "type": "string",
        "minLength": 1
      },
      "requestId": {
        "type": "string",
        "minLength": 1
      },
      "strictCapabilities": {
        "type": "object",
        "properties": {
          "playbackContextV2": {
            "const": true
          },
          "playbackPrepare": {
            "type": "boolean"
          },
          "effectiveAtPlayback": {
            "type": "boolean"
          },
          "canPlay": {
            "type": "boolean"
          },
          "canPause": {
            "type": "boolean"
          },
          "canSeek": {
            "type": "boolean"
          },
          "canSetVolume": {
            "type": "boolean"
          },
          "supportsFollow": {
            "type": "boolean"
          },
          "supportsBroadcast": {
            "type": "boolean"
          }
        },
        "required": [
          "playbackContextV2",
          "playbackPrepare",
          "effectiveAtPlayback",
          "canPlay",
          "canPause",
          "canSeek",
          "canSetVolume",
          "supportsFollow",
          "supportsBroadcast"
        ],
        "additionalProperties": false
      },
      "strictRoles": {
        "type": "array",
        "items": {
          "enum": ["player", "controller"]
        },
        "minItems": 1,
        "maxItems": 2,
        "uniqueItems": true
      },
      "strictRegistrationPayload": {
        "type": "object",
        "properties": {
          "clientId": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "deviceSessionId": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "deviceName": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "alias": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "roles": {
            "$ref": "#/$defs/strictRoles"
          },
          "capabilities": {
            "$ref": "#/$defs/strictCapabilities"
          }
        },
        "required": [
          "clientId",
          "deviceSessionId",
          "deviceName",
          "roles",
          "capabilities"
        ],
        "additionalProperties": false
      },
      "strictClient": {
        "type": "object",
        "properties": {
          "clientId": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "deviceSessionId": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "roles": {
            "$ref": "#/$defs/strictRoles"
          },
          "capabilities": {
            "$ref": "#/$defs/strictCapabilities"
          },
          "userName": {
            "type": "string"
          },
          "deviceName": {
            "type": "string"
          },
          "alias": {
            "type": "string"
          },
          "connectedAt": {
            "type": "number"
          },
          "lastSeenAt": {
            "type": "number"
          }
        },
        "required": [
          "clientId",
          "deviceSessionId",
          "deviceName",
          "roles",
          "capabilities"
        ],
        "not": {
          "required": [
            "sessionId"
          ]
        },
        "additionalProperties": true
      },
      "strictMetadata": {
        "type": "object",
        "properties": {
          "protocolVersion": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "schemaHash": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "serverBuildCommit": {
            "type": "string",
            "pattern": "^(unknown|[0-9a-f]{40})$"
          },
          "connectionNonce": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "connectionEpoch": {
            "type": "integer",
            "const": 1
          }
        },
        "required": [
          "protocolVersion",
          "schemaHash",
          "serverBuildCommit",
          "connectionNonce",
          "connectionEpoch"
        ],
        "additionalProperties": false
      },
      "strictRegisterRequest": {
        "type": "object",
        "properties": {
          "type": {
            "const": "device"
          },
          "action": {
            "const": "device.register"
          },
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "payload": {
            "$ref": "#/$defs/strictRegistrationPayload"
          }
        },
        "required": [
          "type",
          "action",
          "requestId",
          "payload"
        ],
        "additionalProperties": false
      },
      "strictRegisterAck": {
        "type": "object",
        "properties": {
          "type": {
            "const": "system"
          },
          "action": {
            "const": "system.ack"
          },
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "timestamp": {
            "type": "number"
          },
          "connectionNonce": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "connectionEpoch": {
            "type": "integer",
            "const": 1
          },
          "payload": {
            "type": "object",
            "properties": {
              "action": {
                "const": "device.register"
              },
              "clientId": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "deviceSessionId": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "negotiatedCapabilities": {
                "$ref": "#/$defs/strictCapabilities"
              },
              "strictV2": {
                "$ref": "#/$defs/strictMetadata"
              }
            },
            "required": [
              "action",
              "clientId",
              "deviceSessionId",
              "negotiatedCapabilities",
              "strictV2"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "type",
          "action",
          "requestId",
          "timestamp",
          "payload"
        ],
        "additionalProperties": false
      },
      "registerError": {
        "type": "object",
        "properties": {
          "type": {
            "const": "system"
          },
          "action": {
            "const": "system.error"
          },
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "timestamp": {
            "type": "number"
          },
          "connectionNonce": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "connectionEpoch": {
            "type": "integer",
            "const": 1
          },
          "payload": {
            "type": "object",
            "properties": {
              "action": {
                "const": "device.register"
              },
              "code": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "message": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "retryable": {
                "type": "boolean"
              }
            },
            "required": [
              "action",
              "code",
              "message",
              "retryable"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "type",
          "action",
          "requestId",
          "timestamp",
          "payload"
        ],
        "additionalProperties": false
      }
    }
  }
}
